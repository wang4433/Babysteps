__pycache__/
*.pyc
*.pyo
.pytest_cache/
.coverage
*.egg-info/
.DS_Store
datasets/stage0_pushcube_blocked/videos/
datasets/stage0_pushcube_blocked/videos_maniskill/
datasets/stage0_pushcube_blocked/rollouts/
/tmp/

# Render artifacts (MP4s + gate data) — local only, never committed.
# Keep the directory's CLAUDE.md trackable so the docs can still be committed.
renders/*
!renders/CLAUDE.md

# SLURM job logs — artifacts (the gate numbers live in slurm/CLAUDE.md + specs).
slurm/logs/

# Scratch GPU diagnostics — not part of the tested codebase (see scripts/CLAUDE.md).
scripts/_diag_*.py
slurm/_diag_*.sbatch

# Stage-4 trained M2a artifacts (weights + centroids). Derived from
# committed varied_intent data + scripts/stage4_m2a_train_pack.py.
# Reproduce: python scripts/stage4_m2a_train_pack.py --jsonl <samples> --out-dir <here>
models/

# Stage-5 P1 cached demo frames + DINOv2 features. ~40 MB / seed × ~60 seeds
# ≈ 2 GB; large binary artifacts derived from the committed varied_intent cut.
# Reproduce: python scripts/stage5_render_demo_frames.py --jsonl <samples> --out-dir <here>
datasets/stage5/

# Report binary intermediates — the rendered demo strips / before-after frames
# the VLM probes write next to their report.{json,md}. Large, reproducible from
# the gitignored datasets/stage5 cache; only the report.{json,md} are tracked.
reports/**/strips/
reports/**/frames/

# Local Claude Code harness state (scheduled-task lock etc.), not project code.
.claude/
